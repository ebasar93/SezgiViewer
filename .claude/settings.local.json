      "Bash(pkill -x SezgiViewer)",
      "Bash(chmod +x build.sh)",
      "Bash(cp -R build/Release/SezgiViewer.app dmg_staging/)",
      "Bash(ln -s /Applications dmg_staging/Applications)",
      "Bash(hdiutil create *)",
      "Bash(hdiutil attach *)",
      "Read(//tmp/**)",
      "Bash(codesign -dv /tmp/sezgi_dmg_check/SezgiViewer.app)",
      "Bash(hdiutil detach *)",
      "Bash(grep -vE '^total|\\\\.$')"
