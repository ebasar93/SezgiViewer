{
  "permissions": {
    "allow": [
      "Bash(xcode-select -p)",
      "Bash(swift --version)",
      "Bash(sw_vers)",
      "Bash(xcodebuild -project SezgiViewer.xcodeproj -scheme SezgiViewer -configuration Debug -destination 'platform=macOS,arch=arm64' build)",
      "Bash(xcodebuild -project SezgiViewer.xcodeproj -scheme SezgiViewer -configuration Debug -destination 'generic/platform=macOS' SYMROOT=build build)",
      "Bash(xcodebuild -runFirstLaunch)",
      "Bash(xcodebuild -project SezgiViewer.xcodeproj -scheme SezgiViewer -configuration Release -destination 'generic/platform=macOS' SYMROOT=build build)",
